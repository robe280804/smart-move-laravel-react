# Backend API base URL (no trailing slash)
# Staging: https://api.yourdomain.com/api/v1
# Local:   http://localhost:8000/api/v1
VITE_BACKEND_BASE_URL=

# Stripe publishable key (pk_test_... for staging, pk_live_... for production)
VITE_STRIPE_PUBLISHABLE_KEY=

# Stripe payment links (test links for staging, live links for production)
VITE_STRIPE_PAYMENT_LINK_ADVANCED=
VITE_STRIPE_PAYMENT_LINK_PRO=

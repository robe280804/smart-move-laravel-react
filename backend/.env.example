APP_NAME=SmartMove
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ───────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smart_move
DB_USERNAME=root
DB_PASSWORD=
DB_ROOT_PASSWORD=                    # only required for Docker (docker-compose)

# ── Session ────────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Queue & Cache ──────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=redis

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ───────────────────────────────────────────────────────────────────────
# Local: use Mailpit (log driver or smtp on port 1025)
# Staging/Production: use Mailgun, Postmark, or Resend
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@smartmove.app"
MAIL_FROM_NAME="${APP_NAME}"

# ── Stripe / Cashier ───────────────────────────────────────────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=eur

# ── AI (Anthropic) ─────────────────────────────────────────────────────────────
CLAUDE_CODE_API_KEY=
CLAUDE_CODE_MODEL=claude-sonnet-4-6

# ── Qdrant (vector DB for exercise RAG) ───────────────────────────────────────
QDRANT_URL=
QDRANT_KEY=

# ── Auth tokens ────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRATION_TIME=1440    # minutes (1 day)
REFRESH_TOKEN_EXPIRATION_TIME=10080  # minutes (7 days)

# ── Frontend ───────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# ── Sanctum ────────────────────────────────────────────────────────────────────
# Comma-separated list of domains that may receive stateful auth cookies
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1

APP_NAME=SmartMove
APP_ENV=staging
APP_KEY=                             # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://api.yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                    # error or warning in staging, never debug

ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db                           # Docker service name, not 127.0.0.1
DB_PORT=3306
DB_DATABASE=smart_move
DB_USERNAME=smart_move_user
DB_PASSWORD=                         # strong random password
DB_ROOT_PASSWORD=                    # strong random root password (MySQL only)

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Queue & Cache ─────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database            # or redis if you prefer
CACHE_STORE=redis

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis                     # Docker service name
REDIS_PASSWORD=                      # strong random password
REDIS_PORT=6379

# ── Mail (use Mailgun, Postmark, or Resend — NOT Mailpit) ─────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_SCHEME=null
MAIL_USERNAME=                       # your Mailgun SMTP user
MAIL_PASSWORD=                       # your Mailgun SMTP password
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_KEY=pk_test_...               # test key for staging
STRIPE_SECRET=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
CASHIER_CURRENCY=eur
CASHIER_CURRENCY_LOCALE=nl_BE
CASHIER_LOGGER=stack

STRIPE_ADVANCED_PRICE_ID=           # price_... from Stripe dashboard (test mode)
STRIPE_PRO_PRICE_ID=                # price_... from Stripe dashboard (test mode)

STRIPE_CHECKOUT_SUCCESS_URL=https://your-app.vercel.app/dashboard
STRIPE_CHECKOUT_CANCEL_URL=https://your-app.vercel.app/

# ── AI (Anthropic) ────────────────────────────────────────────────────────────
CLAUDE_CODE_API_KEY=sk-ant-...
CLAUDE_CODE_MODEL=claude-sonnet-4-6

# ── Qdrant Cloud ──────────────────────────────────────────────────────────────
QDRANT_URL=https://xxxx.qdrant.io/collections/smart-move-exercise/
QDRANT_KEY=

# ── Token expiration ──────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRATION_TIME=1440    # 1 day in minutes
REFRESH_TOKEN_EXPIRATION_TIME=10080  # 7 days in minutes

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Sanctum ───────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=your-app.vercel.app


